# Copy to ~/.secrets-config — maps env var names to Dashlane secret paths
# Format: KEY=dashlane/path/to/secret
# Run `refresh-secrets` after updating this file

ANTHROPIC_API_KEY=Personal/mac-setup/anthropic-api-key
GITHUB_TOKEN=Personal/mac-setup/github-token
OPENAI_API_KEY=Personal/mac-setup/openai-api-key
AWS_PROFILE=Personal/mac-setup/aws-profile
AWS_REGION=Personal/mac-setup/aws-region
GOOGLE_CLOUD_PROJECT=Personal/mac-setup/google-cloud-project
