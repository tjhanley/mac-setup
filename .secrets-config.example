# Copy to ~/.secrets-config — maps env var names to Dashlane item paths
# Format: KEY=dl://<item-title>/<field>
#   field is "password" for password items, "note" for secure notes
# Run `refresh-secrets` after updating this file
# Run `dcli secret -o json` to inspect item titles and available fields

ANTHROPIC_API_KEY=dl://anthropic-api-key/password
GITHUB_TOKEN=dl://github-token/password
OPENAI_API_KEY=dl://openai-api-key/password
AWS_PROFILE=dl://aws-profile/password
AWS_REGION=dl://aws-region/password
GOOGLE_CLOUD_PROJECT=dl://google-cloud-project/password
