# Ghostty configuration
font-family = "BlexMono Nerd Font"
font-size = 13

window-padding-x = 10
window-padding-y = 10
fullscreen = true
theme = "Catppuccin Mocha"

# Vim-like movement helpers in terminal apps/shells
keybind = alt+h=esc:b
keybind = alt+l=esc:f
keybind = alt+j=csi:B
keybind = alt+k=csi:A

# Shaders (uncomment to enable — installed to ~/.config/ghostty/shaders/)
# custom-shader = ~/.config/ghostty/shaders/crt.glsl
# custom-shader = ~/.config/ghostty/shaders/bloom.glsl
# custom-shader = ~/.config/ghostty/shaders/gradient.glsl
