{
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Catppuccin Mocha"
  },
  "icon_theme": "Catppuccin Icons",
  "auto_install_extensions": {
    "catppuccin": true,
    "catppuccin-icons": true,
    "ghostty": true,
    "html": true,
    "terraform": true,
    "dockerfile": true,
    "toml": true,
    "make": true,
    "env": true
  },
  "vim_mode": true,
  "buffer_font_family": "Dank Mono",
  "buffer_font_size": 15,
  "buffer_line_height": "comfortable",
  "terminal": {
    "font_family": "BlexMono Nerd Font",
    "font_size": 14
  },
  "format_on_save": "on",
  "inlay_hints": {
    "enabled": true
  },
  "tab_size": 2,
  "assistant": {
    "default_model": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-20250514"
    },
    "version": "2"
  }
}
