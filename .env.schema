# Varlock schema — run `varlock run -- <command>` to inject these into a process.
# Sensitive vars are resolved from Dashlane via dcli read dl://<title>/<field>.
# Update paths to match your Dashlane vault item titles.

# @sensitive @required @type=string(startsWith=sk-ant-)
ANTHROPIC_API_KEY=exec('dcli read "dl://anthropic-api-key/password"')

# @sensitive @required
GITHUB_TOKEN=exec('dcli read "dl://github-token/password"')

# @sensitive
OPENAI_API_KEY=exec('dcli read "dl://openai-api-key/password"')

# @type=string
AWS_PROFILE=

# @type=string
AWS_REGION=

# @type=string
GOOGLE_CLOUD_PROJECT=
